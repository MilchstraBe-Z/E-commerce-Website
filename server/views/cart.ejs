<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cart</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/cart.css">
</head>
<body>
    <header>
        <nav>
            <ul>
                <li><a href="/">Home</a></li>
                <li>
                    <% if (typeof user !== 'undefined' && user) { %>
                        <div class="user-button">
                          <a href="/user-portal">
                            <img src="/uploads/icons/user.png" alt="User Portal">
                          </a>
                        </div>
                      <% } else { %>
                        <div class="auth-buttons">
                          <a href="/login" class="login-btn">Login</a>
                          <a href="/register" class="register-btn">Register</a>
                        </div>
                      <% } %>                      
                </li>
            </ul>
        </nav>
    </header>

    <main>
        <h2>Shopping Cart</h2>
        <div id="cart-main-body">
            <ul id="cart-items-list"></ul>
            <p>Total: $<span id="cart-total-price">0.00</span></p>
        </div>

        
        <form id="paypal-form" action="https://www.sandbox.paypal.com/cgi-bin/webscr" method="post">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">

            <input type="hidden" name="cmd" value="_cart">
            <input type="hidden" name="upload" value="1">
            <input type="hidden" name="business" value="sb-lvfsz41252110@business.example.com">
            <input type="hidden" name="currency_code" value="USD">
            <input type="hidden" name="charset" value="utf-8">
          
            <div id="paypal-hidden-fields"></div>
          
            <input type="hidden" name="invoice" id="paypal-invoice">
            <input type="hidden" name="custom" id="paypal-custom">

            <input type="hidden" name="return" value="https://s60.iems5718.ie.cuhk.edu.hk/thank-you">
            <input type="hidden" name="notify_url" value="https://s60.iems5718.ie.cuhk.edu.hk/paypal/webhook">

          
            <button type="submit" id="paypal-submit">Pay</button>
          </form>
          
    </main>

    <footer>
        <p>&copy; ZHY Shopping Site</p>
    </footer>

    <script src="/js/main.js"></script>

</body>
</html>
